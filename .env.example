# Do NOT wrap values in quotation marks below. Tools that read this file
# locally (Next.js, Node's --env-file) strip matching quotes, but if you
# copy a quoted value into a dashboard like Vercel's env var UI, the
# quotes become part of the literal value there and will break things.
# Just: KEY=value  (not KEY="value")

# ---- Public (safe to expose to the browser; used client-side too) --------
# See README-DEMO-SETUP.md for exactly where to find each value.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Public base URL of this deployment (used in emails and redirect links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Server-only (never sent to the browser) ------------------------------
# Bypasses Row Level Security — keep this out of any NEXT_PUBLIC_* variable.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails allowed to access /admin (each must also
# exist as a Supabase Auth user — see README-DEMO-SETUP.md)
ADMIN_EMAILS=

# Resend (leave both blank to use the built-in email-preview fallback —
# booking and confirmation still work without these)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
