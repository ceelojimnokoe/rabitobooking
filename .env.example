# Supabase (see README-DEMO-SETUP.md for exactly where to find each value)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails allowed to access /admin (must also exist
# as Supabase Auth users — see README-DEMO-SETUP.md)
ADMIN_EMAILS=

# Resend (leave both blank to use the built-in email-preview fallback)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Public base URL of this deployment (used in emails and OAuth-style links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
